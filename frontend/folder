async function handleSendReport() {
  const userId = localStorage.getItem('burnout_user_id');
  const emailInput = document.getElementById('userEmail');

  // 👉 Get both values clearly
  const registeredEmail = localStorage.getItem('mg_email');
  const enteredEmail = emailInput && emailInput.value.trim();

  // 👉 Decide final email used
  const email = registeredEmail;
  

  // 🔍 DEBUG LOGS (ADD HERE)
  console.log("📌 Registered Email (localStorage):", registeredEmail);
  console.log("📌 Entered Email (input):", enteredEmail);
  console.log("📌 Final Email Used:", email);

  // 🚨 1. Check email exists
  if (!email) {
    showNotification('⚠️ Enter and subscribe your email first.', 'warning');
    return;
  }

  // 🚨 2. Check backend session
  if (!userId || userId.startsWith('LOCAL_')) {
    showNotification('⚠️ Backend must be running to send a report.', 'warning');
    return;
  }

  const sendBtn = document.getElementById('sendReportBtn');
  const orig = sendBtn.innerHTML;
  sendBtn.disabled = true;
  sendBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';

  try {
    // 🚨 3. VERIFY USER EMAIL FROM BACKEND
    const userResp = await fetch(`${API_BASE_URL}/user/${encodeURIComponent(userId)}`);
    const userData = await userResp.json();

    console.log("📌 Backend Email:", userData.email); // 🔍 DEBUG

    if (!userResp.ok) {
      throw new Error("Failed to verify user");
    }

    // 🚨 4. SAFE COMPARISON (CASE-INSENSITIVE)
    if (
      !userData.email ||
      userData.email.trim().toLowerCase() !== email.trim().toLowerCase()
    ) {
      showNotification('❌ Use your registered login email only!', 'warning');
      sendBtn.disabled = false;
      sendBtn.innerHTML = orig;
      return;
    }

    // 🚀 5. SEND REPORT
    const response = await fetch(
      `${API_BASE_URL}/send/weekly-report?user_id=${encodeURIComponent(userId)}`,
      { method: 'POST' }
    );

    const result = await response.json();

    if (!response.ok || result.status !== 'success') {
      throw new Error(result.message || 'Failed to send report');
    }

    showNotification('✅ Weekly report sent to ' + email + '!', 'success');
    setEmailStatus(
      '<i class="fas fa-paper-plane"></i> Report sent to ' + email,
      'var(--accent2)'
    );

  } catch (e) {
    console.error('Send report error:', e);
    showNotification('❌ ' + e.message, 'warning');
    setEmailStatus(
      '<i class="fas fa-times-circle"></i> Failed: ' + e.message,
      'var(--high)'
    );
  } finally {
    sendBtn.disabled = false;
    sendBtn.innerHTML = orig;
  }
}
